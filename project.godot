; Engine configuration file.
; Updated for Godot 4.6 compatibility

config_version=5

[application]

config/name="RogueLike Demo - Medieval Fantasy"
config/description="A 2D pixel rogue-like game with medieval western fantasy theme v1.0.2"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/icon.svg"

[autoload]

EventBus="*res://scripts/autoload/EventBus.gd"
DataManager="*res://scripts/autoload/DataManager.gd"
GameStateManager="*res://scripts/autoload/GameStateManager.gd"
FactionSystem="*res://scripts/autoload/FactionSystem.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

textures/canvas_textures/default_texture_filter=0

